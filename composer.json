{
    "name": "sumit/qloapps-version-matrix",
    "description": "Local dashboard to test a QloApps folder against multiple PHP/MySQL versions via Docker.",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "smarty/smarty": "^4.3"
    },
    "autoload": {
        "psr-4": {
            "VersionMatrix\\": "src/"
        }
    },
    "scripts": {
        "post-install-cmd": "@php -r \"file_put_contents('vendor/.htaccess', \\\"Require all denied\\n\\\");\"",
        "post-update-cmd": "@php -r \"file_put_contents('vendor/.htaccess', \\\"Require all denied\\n\\\");\""
    }
}
